# Server Configuration
PORT=5000
NODE_ENV=development

# Database (for Render, use MongoDB Atlas cloud URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vision-girls-hostel?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_use_a_strong_random_string
JWT_EXPIRE=7d

# Email Configuration (optional)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password

# Client URL (update with your Vercel frontend URL after deployment)
CLIENT_URL=https://your-frontend-vercel-url.vercel.app

# Demo Mode (set to true if no MongoDB available)
DEMO_MODE=false
